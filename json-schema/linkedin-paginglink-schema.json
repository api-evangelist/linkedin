{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PagingLink",
  "title": "PagingLink",
  "type": "object",
  "properties": {
    "rel": {
      "type": "string",
      "example": "next"
    },
    "href": {
      "type": "string",
      "example": "/v2/complianceEvents?start=10&count=10"
    },
    "type": {
      "type": "string",
      "example": "application/json"
    }
  }
}