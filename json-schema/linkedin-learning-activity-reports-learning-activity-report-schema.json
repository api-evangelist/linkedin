{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-schema/linkedin-learning-activity-reports-learning-activity-report-schema.json",
  "title": "LearningActivityReport",
  "description": "LearningActivityReport from LinkedIn API",
  "type": "object",
  "properties": {
    "latestDataAt": {
      "type": "integer",
      "format": "int64",
      "description": "Timestamp of the latest data included in this report",
      "example": 1632207540000
    },
    "activities": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/LearningActivity"
      }
    },
    "learnerDetails": {
      "$ref": "#/components/schemas/LearnerDetails"
    }
  }
}