{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ErrorDetail",
  "title": "ErrorDetail",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "example": "FORBIDDEN"
    },
    "message": {
      "type": "string",
      "example": "Viewer doesn't have permission to access this resource"
    },
    "status": {
      "type": "integer",
      "example": 403
    }
  }
}