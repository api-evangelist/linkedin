{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-schema/linkedin-talent-recruiter-system-connect-access-token-request-schema.json",
  "title": "AccessTokenRequest",
  "description": "Request body for obtaining access token",
  "type": "object",
  "properties": {
    "grant_type": {
      "type": "string",
      "enum": [
        "client_credentials"
      ],
      "example": "client_credentials"
    },
    "client_id": {
      "type": "string",
      "description": "OAuth 2.0 client ID",
      "example": "78abc123def456"
    },
    "client_secret": {
      "type": "string",
      "description": "OAuth 2.0 client secret",
      "example": "secretXYZ789"
    }
  },
  "required": [
    "grant_type",
    "client_id",
    "client_secret"
  ]
}