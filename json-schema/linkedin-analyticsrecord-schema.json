{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AnalyticsRecord",
  "title": "AnalyticsRecord",
  "type": "object",
  "properties": {
    "dateRange": {
      "type": "object",
      "properties": {
        "start": {
          "$ref": "#/components/schemas/DateInfo"
        },
        "end": {
          "$ref": "#/components/schemas/DateInfo"
        }
      }
    },
    "impressionCount": {
      "type": "integer",
      "example": 15000
    },
    "clickCount": {
      "type": "integer",
      "example": 500
    },
    "likeCount": {
      "type": "integer",
      "example": 250
    },
    "commentCount": {
      "type": "integer",
      "example": 45
    },
    "shareCount": {
      "type": "integer",
      "example": 30
    },
    "engagementRate": {
      "type": "number",
      "format": "double",
      "example": 0.055
    }
  }
}