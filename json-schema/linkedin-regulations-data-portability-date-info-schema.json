{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-schema/linkedin-regulations-data-portability-date-info-schema.json",
  "title": "DateInfo",
  "description": "DateInfo from LinkedIn API",
  "type": "object",
  "properties": {
    "year": {
      "type": "integer",
      "example": 2001
    },
    "month": {
      "type": "integer",
      "example": 1
    },
    "day": {
      "type": "integer",
      "example": 15
    }
  }
}