{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-schema/linkedin-marketing-campaigns-paging-schema.json",
  "title": "Paging",
  "description": "Paging from LinkedIn API",
  "type": "object",
  "properties": {
    "start": {
      "type": "integer",
      "example": 0
    },
    "count": {
      "type": "integer",
      "example": 10
    },
    "total": {
      "type": "integer",
      "example": 100
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}