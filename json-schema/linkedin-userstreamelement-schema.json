{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/UserStreamElement",
  "title": "UserStreamElement",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "ADD",
        "REMOVE"
      ],
      "description": "Action to perform",
      "example": "ADD"
    },
    "userIds": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/UserId"
      }
    }
  },
  "required": [
    "action",
    "userIds"
  ]
}