{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DateInfo",
  "title": "DateInfo",
  "type": "object",
  "properties": {
    "year": {
      "type": "integer",
      "example": 2001
    },
    "month": {
      "type": "integer",
      "example": 1
    },
    "day": {
      "type": "integer",
      "example": 15
    }
  }
}