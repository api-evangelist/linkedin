{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Comment",
  "title": "Comment",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "urn:li:comment:(urn:li:share:123,456)"
    },
    "actor": {
      "type": "string",
      "example": "urn:li:person:ABC123"
    },
    "message": {
      "type": "string",
      "example": "Great post!"
    },
    "created": {
      "$ref": "#/components/schemas/Timestamp"
    },
    "lastModified": {
      "$ref": "#/components/schemas/Timestamp"
    }
  }
}