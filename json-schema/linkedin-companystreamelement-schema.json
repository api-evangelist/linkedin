{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CompanyStreamElement",
  "title": "CompanyStreamElement",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "ADD",
        "REMOVE"
      ],
      "description": "Action to perform",
      "example": "ADD"
    },
    "companyName": {
      "type": "string",
      "description": "Company name to add or remove",
      "example": "LinkedIn"
    },
    "companyDomain": {
      "type": "string",
      "description": "Company domain (optional)",
      "example": "linkedin.com"
    },
    "companyPageUrl": {
      "type": "string",
      "description": "Company LinkedIn page URL (optional)",
      "example": "https://www.linkedin.com/company/linkedin"
    }
  },
  "required": [
    "action",
    "companyName"
  ]
}