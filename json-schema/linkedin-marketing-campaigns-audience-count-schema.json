{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-schema/linkedin-marketing-campaigns-audience-count-schema.json",
  "title": "AudienceCount",
  "description": "AudienceCount from LinkedIn API",
  "type": "object",
  "properties": {
    "total": {
      "type": "integer",
      "description": "Total audience count",
      "example": 1500000
    },
    "activeCount": {
      "type": "integer",
      "description": "Active member count",
      "example": 1200000
    }
  }
}