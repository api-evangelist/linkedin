{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-schema/linkedin-compliance-events-paging-link-schema.json",
  "title": "PagingLink",
  "description": "PagingLink from LinkedIn API",
  "type": "object",
  "properties": {
    "rel": {
      "type": "string",
      "example": "next"
    },
    "href": {
      "type": "string",
      "example": "/v2/complianceEvents?start=10&count=10"
    },
    "type": {
      "type": "string",
      "example": "application/json"
    }
  }
}