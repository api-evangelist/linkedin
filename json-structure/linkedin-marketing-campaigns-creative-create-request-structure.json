    "reference": {
      "type": "string",
      "example": "urn:li:ugcPost:123456789"
    },
    "status": {
      "type": "string",
      "example": "ACTIVE"
    },
    "type": {
      "type": "string",
      "example": "SPONSORED_VIDEO"
    },
    "variables": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object"
        }
      }
    }
  },
  "required": [
    "campaign",
    "reference",
    "status",
    "type"
  ]
}