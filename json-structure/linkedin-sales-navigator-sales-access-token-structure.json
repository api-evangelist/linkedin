{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-structure/linkedin-sales-navigator-sales-access-token-structure.json",
  "name": "SalesAccessToken",
  "description": "SalesAccessToken from LinkedIn API",
  "type": "object",
  "properties": {
    "token": {
      "type": "string",
      "description": "Short-lived, limited-scope OAuth token",
      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
    },
    "expiryTime": {
      "type": "int32",
      "description": "Time at which this token will become invalid (seconds since epoch)",
      "example": 1640100000
    }
  },
  "required": [
    "token",
    "expiryTime"
  ]
}