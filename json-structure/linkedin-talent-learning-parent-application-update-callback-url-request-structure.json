{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-structure/linkedin-talent-learning-parent-application-update-callback-url-request-structure.json",
  "name": "UpdateCallbackUrlRequest",
  "description": "Request body for updating OAuth 2.0 callback URLs",
  "type": "object",
  "properties": {
    "patch": {
      "type": "object",
      "properties": {
        "$set": {
          "type": "object",
          "properties": {
            "oauth2AuthorizedCallbackUrls": {
              "type": "array",
              "items": {
                "type": "uri"
              },
              "example": [
                "https://app.acme.com/oauth2/callback",
                "https://new-domain.acme.com/oauth2/callback"
              ]
            }
          }
        }
      }
    }
  },
  "required": [
    "patch"
  ]
}