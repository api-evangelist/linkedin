{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-structure/linkedin-marketing-audience-company-stream-element-structure.json",
  "name": "CompanyStreamElement",
  "description": "CompanyStreamElement from LinkedIn API",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "ADD",
        "REMOVE"
      ],
      "description": "Action to perform",
      "example": "ADD"
    },
    "companyName": {
      "type": "string",
      "description": "Company name to add or remove",
      "example": "LinkedIn"
    },
    "companyDomain": {
      "type": "string",
      "description": "Company domain (optional)",
      "example": "linkedin.com"
    },
    "companyPageUrl": {
      "type": "string",
      "description": "Company LinkedIn page URL (optional)",
      "example": "https://www.linkedin.com/company/linkedin"
    }
  },
  "required": [
    "action",
    "companyName"
  ]
}