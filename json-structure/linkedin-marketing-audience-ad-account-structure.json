{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/linkedin/refs/heads/main/json-structure/linkedin-marketing-audience-ad-account-structure.json",
  "name": "AdAccount",
  "description": "AdAccount from LinkedIn API",
  "type": "object",
  "properties": {
    "id": {
      "type": "int64",
      "description": "Unique identifier for the ad account",
      "example": 123456
    },
    "name": {
      "type": "string",
      "description": "Display name of the ad account",
      "example": "Test ad account"
    },
    "reference": {
      "type": "string",
      "description": "Reference URN (organization) for the ad account",
      "example": "urn:li:organization:11223344"
    },
    "test": {
      "type": "boolean",
      "description": "Whether this is a test ad account",
      "example": false
    }
  },
  "required": [
    "id",
    "name",
    "test"
  ]
}